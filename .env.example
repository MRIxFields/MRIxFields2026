# =============================================================================
# MRIxFields2026 — Environment Configuration
# =============================================================================
# Copy this file to .env and edit the paths to match your environment:
#   cp .env.example .env
#   vim .env
#   source .env          # load into current shell (for bash/shell commands)
#
# Python scripts auto-load .env via mrixfields.env.load_env().
# For shell commands using $DATA_DIR etc., run `source .env` first.
#
# .env is gitignored and will not be committed.
# =============================================================================

# Root directory of the released dataset (must exist; ~150 GB)
DATA_DIR=/path/to/MRIxFields2026_Data

# Preprocessed npz directory (created by preprocess.py extract-slices; ~50 GB)
PREPROCESSED_DIR=./Baseline/preprocessed

# Root directory for training outputs: checkpoints, logs (auto-created; ~5-20 GB per experiment)
OUTPUT_DIR=./Baseline/runs

# Directory for inference predictions (auto-created; ~10 GB per task)
INFERENCE_DIR=./Baseline/predictions

# SynthSeg installation path (for brain segmentation; see Evaluation/README.md)
SYNTHSEG_DIR=/path/to/SynthSeg

# GPU device
DEVICE=cuda:0
